# === AI 模型配置（至少配置一个）===
# 方案一：Google Gemini（免费，推荐）
# 从 https://aistudio.google.com/app/apikey 获取
GEMINI_API_KEY=

# 方案二：DeepSeek（极低成本）
# 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 方案三：OpenAI 兼容接口（通义千问、智谱等）
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# === 飞书推送配置 ===
# 飞书机器人 Webhook URL（从飞书群 -> 设置 -> 群机器人 -> 添加机器人 获取）
FEISHU_WEBHOOK_URL=

# === 股票关注列表 ===
# 自选股代码，逗号分隔，带市场前缀
# A股: 000001, 600519  （不需要前缀）
# 港股: 00700.HK
# 美股: AAPL
STOCK_WATCHLIST=000001,600519,300750,002594

# === 运行模式 ===
# pre_market | intraday | post_market | all
RUN_MODE=all
